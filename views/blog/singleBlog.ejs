<%- include('../partials/header') %>

          <div class="content-wrapper">
            <div class="container-xxl flex-grow-1 container-p-y">
              <div class="row justify-content-center">
                <div class="col-xl-9 col-lg-10">
                  <div class="card">
                    <img src="/uploads/blogs/<%= blog.image %>" class="card-img-top" alt="blog" style="max-height:430px;object-fit:cover">
                    <div class="card-body">
                      <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
                        <div>
                          <h4 class="mb-1"><%= blog.title %></h4>
                          <p class="text-body-secondary mb-0">By <%= blog.authername %></p>
                        </div>
                        <div class="d-flex gap-2 flex-wrap">
                          <a href="/edit-blog/<%= blog._id %>" class="btn btn-outline-warning btn-sm">Update</a>
                          <a href="/delete-blog/<%= blog._id %>" onclick="return confirm('Are you sure you want to delete this blog?')" class="btn btn-outline-danger btn-sm">Delete</a>
                          <a href="/view-blog" class="btn btn-outline-secondary btn-sm">Back</a>
                        </div>
                      </div>
                      <p class="mb-0" style="white-space:pre-line"><%= blog.desc %></p>
                    </div>
                  </div>
                </div>
              </div>
            </div>

<%- include('../partials/footer') %>
