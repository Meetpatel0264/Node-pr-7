<%- include('../partials/header') %>

          <div class="content-wrapper">
            <div class="container-xxl flex-grow-1 container-p-y">
              <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                  <h5 class="mb-0">View Blog</h5>
                  <a href="/add-blog" class="btn btn-sm btn-primary">Add Blog</a>
                </div>
                <div class="card-body">
                  <div class="row gy-5">
                    <% if (blogs && blogs.length) { %>
                      <% blogs.forEach((blog) => { %>
                        <div class="col-md-6 col-xl-4">
                          <div class="card h-100 border shadow-none">
                            <a href="/blog/<%= blog._id %>">
                              <img class="card-img-top" src="/uploads/blogs/<%= blog.image %>" alt="blog" style="height:220px;object-fit:cover">
                            </a>
                            <div class="card-body">
                              <h5 class="card-title">
                                <a href="/blog/<%= blog._id %>" class="text-heading"><%= blog.title %></a>
                              </h5>
                              <p class="text-body-secondary mb-2">By <%= blog.authername %></p>
                              <p class="card-text"><%= blog.desc.length > 90 ? blog.desc.substring(0, 90) + '...' : blog.desc %></p>
                              <div class="d-flex gap-2 flex-wrap">
                                <a href="/blog/<%= blog._id %>" class="btn btn-outline-primary btn-sm">View</a>
                                <a href="/edit-blog/<%= blog._id %>" class="btn btn-outline-warning btn-sm">Update</a>
                                <a href="/delete-blog/<%= blog._id %>" onclick="return confirm('Are you sure you want to delete this blog?')" class="btn btn-outline-danger btn-sm">Delete</a>
                              </div>
                            </div>
                          </div>
                        </div>
                      <% }) %>
                    <% } else { %>
                      <div class="col-12 text-center py-5">
                        <h6>No blog found</h6>
                        <p class="text-body-secondary">Click add blog and upload your first blog.</p>
                        <a href="/add-blog" class="btn btn-primary">Add Blog</a>
                      </div>
                    <% } %>
                  </div>
                </div>
              </div>
            </div>

<%- include('../partials/footer') %>
